{
  "name": "ui-agent-demo",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/ui-agent-demo/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "rm -rf dist && pnpm exec tsc --project tsconfig.build.json",
        "cwd": "{workspaceRoot}/packages/ui-agent-demo"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec tsx --tsconfig tsconfig.app.json watch src/index.tsx",
        "cwd": "{workspaceRoot}/packages/ui-agent-demo"
      },
      "cache": false
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec tsx --tsconfig tsconfig.app.json src/index.tsx",
        "cwd": "{workspaceRoot}/packages/ui-agent-demo"
      },
      "cache": false
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec biome check packages/ui-agent-demo",
        "cwd": "{workspaceRoot}"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec vitest run --config packages/ui-agent-demo/vitest.config.ts",
        "cwd": "{workspaceRoot}"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec tsc --project packages/ui-agent-demo/tsconfig.app.json --noEmit",
        "cwd": "{workspaceRoot}"
      }
    }
  },
  "tags": []
}
