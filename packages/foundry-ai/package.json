{
  "name": "@nyrra/foundry-ai",
  "version": "0.0.4",
  "description": "Thin Palantir Foundry provider adapters and model catalog for the Vercel AI SDK.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nyrra-labs/nyrra-foundry-ai.git"
  },
  "homepage": "https://github.com/nyrra-labs/nyrra-foundry-ai/tree/main/packages/foundry-ai#readme",
  "bugs": {
    "url": "https://github.com/nyrra-labs/nyrra-foundry-ai/issues"
  },
  "keywords": [
    "ai",
    "ai-sdk",
    "ai-sdk-provider",
    "foundry",
    "llm-proxy",
    "nyrra",
    "palantir",
    "palantir-foundry",
    "ts",
    "vercel-ai-sdk"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./openai": {
      "types": "./dist/providers/openai.d.ts",
      "import": "./dist/providers/openai.mjs",
      "require": "./dist/providers/openai.cjs"
    },
    "./anthropic": {
      "types": "./dist/providers/anthropic.d.ts",
      "import": "./dist/providers/anthropic.mjs",
      "require": "./dist/providers/anthropic.cjs"
    },
    "./google": {
      "types": "./dist/providers/google.d.ts",
      "import": "./dist/providers/google.mjs",
      "require": "./dist/providers/google.cjs"
    }
  },
  "files": [
    "dist",
    "docs",
    "skills",
    "LICENSE",
    "NOTICE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@tanstack/intent": "0.0.27"
  },
  "peerDependencies": {
    "ai": "^6.0.141",
    "@ai-sdk/anthropic": "^3.0.64",
    "@ai-sdk/google": "^3.0.54",
    "@ai-sdk/openai": "^3.0.49"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/anthropic": {
      "optional": true
    },
    "@ai-sdk/google": {
      "optional": true
    },
    "@ai-sdk/openai": {
      "optional": true
    }
  }
}
