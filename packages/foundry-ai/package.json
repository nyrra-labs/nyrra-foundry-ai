{
  "name": "@nyrra-labs/foundry-ai",
  "version": "0.0.1",
  "description": "Thin Foundry provider adapters and model catalog for the Vercel AI SDK.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./openai": {
      "types": "./dist/providers/openai.d.ts",
      "import": "./dist/providers/openai.mjs",
      "require": "./dist/providers/openai.cjs"
    },
    "./anthropic": {
      "types": "./dist/providers/anthropic.d.ts",
      "import": "./dist/providers/anthropic.mjs",
      "require": "./dist/providers/anthropic.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "ai": "^6.0.138",
    "@ai-sdk/anthropic": "^3.0.64",
    "@ai-sdk/openai": "^3.0.48"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/anthropic": {
      "optional": true
    },
    "@ai-sdk/openai": {
      "optional": true
    }
  }
}
