{
  "name": "foundry-ai",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/foundry-ai/src",
  "projectType": "library",
  "targets": {
    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node scripts/clean.mjs",
        "cwd": "{workspaceRoot}"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "pnpm exec tsup --config tsup.config.ts",
        "cwd": "{workspaceRoot}/packages/foundry-ai"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec biome check .github AGENTS.md README.md SECURITY.md biome.json docs examples justfile nx.json opencode.jsonc package.json packages/foundry-ai pnpm-workspace.yaml scripts tsconfig.base.json tsconfig.json",
        "cwd": "{workspaceRoot}"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec vitest run --config packages/foundry-ai/vitest.config.ts",
        "cwd": "{workspaceRoot}"
      }
    },
    "test-live": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node scripts/run-live-capability-suite.mjs",
        "cwd": "{workspaceRoot}"
      },
      "cache": false
    },
    "docs-live-matrix": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node scripts/update-live-matrix-docs.mjs",
        "cwd": "{workspaceRoot}"
      },
      "cache": false
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          {
            "command": "pnpm exec tsc --project packages/foundry-ai/tsconfig.typecheck.json --noEmit",
            "description": "TypeScript typecheck"
          }
        ],
        "parallel": false,
        "cwd": "{workspaceRoot}"
      }
    }
  },
  "tags": [],
  "release": {
    "version": {
      "manifestRootsToUpdate": ["{projectRoot}"]
    }
  }
}
