{
  "name": "nyrra-foundry-ai",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "build": "pnpm exec nx run foundry-ai:build",
    "format": "pnpm exec biome check --write .",
    "lint": "pnpm exec nx run foundry-ai:lint",
    "test": "pnpm exec nx run foundry-ai:test",
    "test:live": "pnpm exec nx run foundry-ai:test-live",
    "typecheck": "pnpm exec nx run foundry-ai:typecheck",
    "deprecations": "node scripts/check-deprecations.mjs --project packages/foundry-ai/tsconfig.typecheck.json",
    "release": "pnpm exec nx release"
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "3.0.64",
    "@ai-sdk/openai": "3.0.48",
    "@biomejs/biome": "2.3.0",
    "@exalabs/ai-sdk": "2.0.1",
    "@nx/js": "21.0.0",
    "@swc-node/register": "~1.9.1",
    "@swc/core": "~1.5.7",
    "@swc/helpers": "~0.5.11",
    "@types/node": "22.19.15",
    "ai": "6.0.138",
    "nx": "21.0.0",
    "tslib": "2.8.1",
    "tsup": "8.0.0",
    "tsx": "4.21.0",
    "typescript": "5.8.3",
    "vitest": "3.2.0",
    "zod": "4.3.6"
  }
}
