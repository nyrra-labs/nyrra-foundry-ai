{
  "name": "nyrra-foundry-ai",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "build": "pnpm exec nx run foundry-ai:build --outputStyle=static",
    "clean": "pnpm exec nx run foundry-ai:clean --outputStyle=static",
    "example": "node scripts/run-example.mjs",
    "example:devtools": "node scripts/run-example.mjs tool-calling-devtools",
    "example:devtools:parallel": "node scripts/run-example.mjs tool-calling-parallel-devtools",
    "format": "pnpm exec biome check --write .",
    "lint": "pnpm exec nx run foundry-ai:lint --outputStyle=static",
    "release": "node scripts/create-stable-release-pr.mjs",
    "test": "pnpm exec nx run foundry-ai:test --outputStyle=static",
    "test:live": "pnpm exec nx run foundry-ai:test-live --outputStyle=stream-without-prefixes",
    "test:live:full": "pnpm run test:live -- --catalog",
    "test:live:devtools": "pnpm exec nx run foundry-ai:test-live-devtools --outputStyle=stream-without-prefixes",
    "test:live:devtools:full": "pnpm run test:live:devtools -- --catalog",
    "test:live:summary": "node scripts/update-harness-results-docs.mjs --stdout",
    "typecheck": "pnpm exec nx run foundry-ai:typecheck --outputStyle=static"
  },
  "pnpm": {
    "overrides": {
      "handlebars": ">=4.7.9",
      "brace-expansion": ">=4.0.1",
      "picomatch": ">=4.0.4",
      "minimatch@<10": ">=10.0.0"
    }
  },
  "devDependencies": {
    "@ai-sdk/devtools": "0.0.15",
    "@ai-sdk/anthropic": "3.0.71",
    "@ai-sdk/google": "3.0.64",
    "@ai-sdk/openai": "3.0.53",
    "@biomejs/biome": "2.4.12",
    "@exalabs/ai-sdk": "2.0.1",
    "@nx/js": "22.6.5",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.30",
    "@swc/helpers": "~0.5.21",
    "@tanstack/intent": "0.0.29",
    "@types/node": "25.6.0",
    "ai": "6.0.168",
    "nx": "22.6.5",
    "tslib": "2.8.1",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vitest": "4.1.4",
    "zod": "4.3.6"
  }
}
