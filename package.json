{
  "name": "foundry-ai",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "build": "pnpm exec nx run foundry-ai:build --outputStyle=static",
    "clean": "pnpm exec nx run foundry-ai:clean --outputStyle=static",
    "example": "node scripts/run-example.mjs",
    "example:devtools": "node scripts/run-example.mjs tool-calling-devtools",
    "example:devtools:parallel": "node scripts/run-example.mjs tool-calling-parallel-devtools",
    "format": "pnpm exec biome check --write .",
    "identity-check": "node scripts/check-neutral-identity.mjs",
    "lint": "pnpm exec nx run foundry-ai:lint --outputStyle=static",
    "release-policy-check": "node scripts/check-release-policy.mjs",
    "release": "node scripts/create-stable-release-pr.mjs",
    "test": "pnpm exec nx run foundry-ai:test --outputStyle=static",
    "test:live": "pnpm exec nx run foundry-ai:test-live --outputStyle=stream-without-prefixes",
    "test:live:full": "pnpm run test:live -- --catalog",
    "test:live:devtools": "pnpm exec nx run foundry-ai:test-live-devtools --outputStyle=stream-without-prefixes",
    "test:live:devtools:full": "pnpm run test:live:devtools -- --catalog",
    "test:live:summary": "node scripts/update-harness-results-docs.mjs --stdout",
    "typecheck": "pnpm exec nx run foundry-ai:typecheck --outputStyle=static",
    "verify": "pnpm exec nx run-many -t identity-check release-policy-check lint test typecheck build skills-validate package-audit --projects=foundry-ai --outputStyle=static",
    "verify:public-metadata": "node scripts/verify-public-metadata.mjs"
  },
  "pnpm": {
    "overrides": {
      "@babel/core@7": "7.29.6",
      "@babel/plugin-transform-modules-systemjs@7": "7.29.7",
      "@hono/node-server@1": "1.19.13",
      "ajv@8": "8.18.0",
      "handlebars": ">=4.7.9",
      "brace-expansion@4": "4.0.1",
      "brace-expansion@5": "5.0.6",
      "fast-uri@3": "3.1.2",
      "form-data@4": "4.0.6",
      "js-yaml@4": "4.2.0",
      "lodash@4": "4.18.0",
      "picomatch": ">=4.0.4",
      "minimatch@<10": ">=10.0.0",
      "qs@6": "6.15.2",
      "vite@6": "6.4.3"
    }
  },
  "devDependencies": {
    "@ai-sdk/devtools": "1.0.4",
    "@ai-sdk/anthropic": "4.0.12",
    "@ai-sdk/google": "4.0.12",
    "@ai-sdk/openai": "4.0.11",
    "@biomejs/biome": "2.5.3",
    "@exalabs/ai-sdk": "2.1.0",
    "@nx/js": "23.0.2",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.43",
    "@swc/helpers": "~0.5.23",
    "@tanstack/intent": "0.3.5",
    "@types/node": "26.1.1",
    "ai": "7.0.22",
    "nx": "23.0.2",
    "tslib": "2.8.1",
    "tsup": "8.5.1",
    "tsx": "4.23.0",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vitest": "4.1.10",
    "yaml": "2.9.0",
    "zod": "4.4.3"
  }
}
